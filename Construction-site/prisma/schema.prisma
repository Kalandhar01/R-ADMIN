generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConstructionLeadStatus {
  new
  contacted
  qualified
  proposal_sent
  won
  lost
}

model ConstructionLead {
  id               String                        @id @default(cuid())
  fullName         String
  email            String
  phone            String?
  selectedServices String[]                      @default([])
  projectType      String?
  projectLocation  String?
  budgetRange      String?
  timeline         String?
  message          String?                       @db.Text
  status           ConstructionLeadStatus        @default(new)
  notes            String?                       @db.Text
  source           String                        @default("consultation-form")
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  statusHistory    ConstructionLeadStatusHistory[]

  @@index([email])
  @@index([status, createdAt])
  @@index([status])
  @@index([createdAt])
}

model ConstructionLeadStatusHistory {
  id         String           @id @default(cuid())
  leadId     String
  fromStatus String?
  toStatus   String
  changedBy  String?
  note       String?          @db.Text
  createdAt  DateTime         @default(now())
  lead       ConstructionLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}
